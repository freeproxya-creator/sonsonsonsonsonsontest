function buildInventoryGearLines()
    local inv = PlayerReplica and PlayerReplica.Data and PlayerReplica.Data.Inventory
    if type(inv) ~= "table" then return "none" end
    local lines = {}
    for _, cat in MAIL_GEAR_CATEGORIES do
        local bucket = inv[cat]
        if type(bucket) == "table" then
            for name, count in pairs(bucket) do
                if type(count) == "number" and count > 0 then lines[#lines + 1] = string.format("%s x%d", name, count) end
            end
        end
    end
    table.sort(lines)
    return #lines > 0 and table.concat(lines, "\n") or "none"
end

function buildInventoryPetLines()
    local inv = PlayerReplica and PlayerReplica.Data and PlayerReplica.Data.Inventory
    local bucket = inv and inv.Pets
    if type(bucket) ~= "table" then return "none" end
    local counts = {}
    for _, entry in pairs(bucket) do
        if type(entry) == "table" then
            local name = entry.Name or entry.PetName or "Pet"
            counts[name] = (counts[name] or 0) + 1
        end
    end
    local lines = {}
    for name, count in pairs(counts) do lines[#lines + 1] = string.format("%s x%d", name, count) end
    table.sort(lines)
    return #lines > 0 and table.concat(lines, "\n") or "none"
end

