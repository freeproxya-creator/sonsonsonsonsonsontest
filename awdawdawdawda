function collectWaterTargets()
    local targets = {}
    for plantId, plantData in pairs(trackedPlants) do
        if type(plantData) ~= "table" then continue end
        local seed = getPlantSeedName(plantData)
        if not seedInSet(selectedWaterPlants, seed) then continue end
        local age = plantData.Age or 0
        local maxAge = plantData.MaxAge or 0
        if maxAge > 0 and age >= maxAge then continue end
        local pos = extractPlantDataPosition(plantData)
        if pos then
            targets[#targets + 1] = { plantId = plantId, seedName = seed, position = pos }
        end
    end
    if #targets == 0 then
        refreshOwnerPlot()
        local pf = OwnerPlot and OwnerPlot:FindFirstChild("Plants")
        if pf then
            for _, plant in pf:GetChildren() do
                local seed = plant:GetAttribute("SeedName") or plant:GetAttribute("PlantName")
                if not seedInSet(selectedWaterPlants, seed) then continue end
                local part = plant.PrimaryPart or plant:FindFirstChildWhichIsA("BasePart", true)
                if part then
                    targets[#targets + 1] = {
                        plantId = plant:GetAttribute("PlantId") or plant.Name,
                        seedName = seed,
                        position = part.Position,
                    }
                end
            end
        end
    end
    local playerFlat = getPlayerFlatPos()
    table.sort(targets, function(a, b)
        local da = playerFlat and flatDistXZ(a.position, playerFlat) or 0
        local db = playerFlat and flatDistXZ(b.position, playerFlat) or 0
        return da < db
    end)
    return targets
end

