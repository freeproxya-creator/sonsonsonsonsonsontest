function isLikelyShopRestock(oldSnap, newSnap)
    if not oldSnap or not next(oldSnap) then return false end
    local increased, appeared = 0, 0
    for key, val in newSnap do
        local prev = oldSnap[key] or 0
        if val > prev then increased += 1 end
        if prev <= 0 and val > 0 then appeared += 1 end
    end
    return increased >= 2 or appeared >= 2
end

function onShopRestockDetected()
    if webhookPetShopUrl == "" then return end
