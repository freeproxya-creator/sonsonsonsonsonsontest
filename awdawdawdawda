function scanNetFavoriteRemotes()
    local found = {}
    local function walk(node, path)
        if type(node) ~= "table" then return end
        for k, v in node do
            local p = path .. "." .. tostring(k)
            if type(k) == "string" and string.find(string.lower(k), "fav", 1, true) then
                if type(v) == "table" and (type(v.Fire) == "function" or type(v.FireServer) == "function" or type(v.InvokeServer) == "function") then
                    found[#found + 1] = { remote = v, path = p }
                end
            end
            if type(v) == "table" and type(v.Fire) ~= "function" and type(v.FireServer) ~= "function" then
                walk(v, p)
            end
        end
    end
    if Net then walk(Net, "Net") end
    return found
end

function fireFavoriteRemote(remote, fruitId, wantFavorite)
    if not remote or fruitId == nil then return false end
    local idStr = tostring(fruitId)
    local tries = {
        function() return safeNetCall(remote, "HarvestedFruits", fruitId, wantFavorite) end,
        function() return safeNetCall(remote, "HarvestedFruits", idStr, wantFavorite) end,
        function() return safeNetCall(remote, fruitId, "HarvestedFruits", wantFavorite) end,
        function() return safeNetCall(remote, fruitId, wantFavorite) end,
        function() return safeNetCall(remote, idStr, wantFavorite) end,
        function() return safeNetCall(remote, wantFavorite, fruitId) end,
        function() return safeNetCall(remote, "HarvestedFruits", fruitId) end,
        function() return safeNetCall(remote, fruitId) end,
        function() return safeNetCall(remote, idStr) end,
        function() return safeNetCall(remote, "HarvestedFruits", fruitId, wantFavorite and true or false) end,
        function() return safeNetCall(remote, { Category = "HarvestedFruits", ItemKey = fruitId, Favorite = wantFavorite }) end,
        function() return safeNetCall(remote, { Category = "HarvestedFruits", Id = fruitId, Favorite = wantFavorite }) end,
        function() return safeNetCall(remote, "HarvestedFruits", { Id = fruitId, Favorite = wantFavorite }) end,
        function() return safeNetCall(remote, { ItemType = "HarvestedFruits", Id = fruitId, State = wantFavorite }) end,
    }
    for _, fn in tries do
        if fn() then return true end
    end
    return false
end

