function normalizeMoonDisplayName(name)
    if name == "Goldmoon" then return "Gold Moon" end
    return name or "Moon"
end

function getWeatherNameForCyclePhase(cyc, pi)
    if pi == 0 then return "Day" end
    if pi == 1 then return "Sunset" end
    local idx = cyc - MOON_WEATHER_START_CYCLE + 1
    return MOON_WEATHER_SEQ[idx] or "Moon"
end

function weatherAtUnix(t)
    local cyc = math.floor(t / MOON_WEATHER_CLEN)
    local into = t - cyc * MOON_WEATHER_CLEN
    local pi = 0
    for i = 2, #MOON_WEATHER_PHASES do
        if into >= MOON_WEATHER_PHASES[i].offset then pi = i - 1 end
    end
    local name = getWeatherNameForCyclePhase(cyc, pi)
    local nextOff = (pi + 1 < #MOON_WEATHER_PHASES) and MOON_WEATHER_PHASES[pi + 2].offset or MOON_WEATHER_CLEN
    return {
        name = name,
        phaseName = MOON_WEATHER_PHASES[pi + 1].name,
        secsLeft = math.max(0, cyc * MOON_WEATHER_CLEN + nextOff - t),
        cyc = cyc,
        pi = pi,
    }
end

function upcomingWeatherEvents(limit)
    limit = limit or 12
    local t = os.time()
    local out = {}
    local cur = weatherAtUnix(t)
    if not cur then return out end
    local cyc, pi = cur.cyc, cur.pi
    for _ = 1, 400 do
        pi += 1
        if pi >= #MOON_WEATHER_PHASES then pi = 0; cyc += 1 end
        local idx = cyc - MOON_WEATHER_START_CYCLE + 1
        if idx < 1 or idx > #MOON_WEATHER_SEQ then break end
        local name = getWeatherNameForCyclePhase(cyc, pi)
        if not MOON_WEATHER_SKIP[name] then
            local startT = cyc * MOON_WEATHER_CLEN + MOON_WEATHER_PHASES[pi + 1].offset
            out[#out + 1] = { name = normalizeMoonDisplayName(name), eta = math.max(0, startT - t) }
            if #out >= limit then break end
        end
    end
    return out
end

function getMoonPredictionRows(limit)
    limit = limit or 4
    local out = {}
    local cur = weatherAtUnix(os.time())
    if cur and cur.name and not MOON_WEATHER_SKIP[cur.name] and cur.secsLeft > 0 then
        out[#out + 1] = { name = normalizeMoonDisplayName(cur.name), eta = cur.secsLeft, now = true }
    end
    for _, ev in upcomingWeatherEvents(24) do
        if (ev.eta or 0) <= 0 then continue end
        local seen = false
        for _, e in out do
            if e.name == ev.name and math.abs(e.eta - ev.eta) < 3 then seen = true break end
        end
        if not seen then out[#out + 1] = ev end
        if #out >= limit then break end
    end
    return out
end

function formatEtaShort(sec)
    sec = math.max(0, math.floor(sec + 0.5))
    local h = math.floor(sec / 3600)
    local m = math.floor((sec % 3600) / 60)
    local s = sec % 60
    if h > 0 then return string.format("%dh%dm%ds", h, m, s) end
    return string.format("%dm%ds", m, s)
end

function getWeatherPredictionList(limit)
    limit = limit or 12
    local out = {}
    for _, ev in ipairs(upcomingWeatherEvents(400)) do
        if (ev.eta or 0) > 0 then
            out[#out + 1] = ev
            if #out >= limit then break end
        end
    end
    return out
end

function buildWeatherPredictText()
    local lines = {}
    for _, ev in ipairs(getWeatherPredictionList(12)) do
        lines[#lines + 1] = string.format("%s | %s", ev.name, formatEtaLong(ev.eta))
    end
    return #lines > 0 and table.concat(lines, "\n") or "No upcoming events"
end

function buildWeatherLiveText()
    local cur = weatherAtUnix(os.time())
    if not cur then return "— | —" end
    local name = normalizeMoonDisplayName(cur.name or cur.phaseName or "?")
    return string.format("%s | %s", name, formatEtaLong(cur.secsLeft or 0))
end

