hubLoop(function()
    local function refreshLive()
        xpcall(function()
            if seedShopLive and type(seedShopLive.SetDesc) == "function" then seedShopLive:SetDesc(buildSeedShopText()) end
            if gearShopLive and type(gearShopLive.SetDesc) == "function" then gearShopLive:SetDesc(buildGearShopText()) end
        end, noopErr)
    end
    local function refreshPredict()
        xpcall(function()
            if seedShopPredict and type(seedShopPredict.SetDesc) == "function" then seedShopPredict:SetDesc(buildSeedShopPredictText()) end
            if gearShopPredict and type(gearShopPredict.SetDesc) == "function" then gearShopPredict:SetDesc(buildGearShopPredictText()) end
        end, noopErr)
    end
    task.wait(2)
    refreshLive()
    refreshPredict()
    refreshWeatherTab()
    local stockRoot = Services.ReplicatedStorage:FindFirstChild("StockValues")
    if stockRoot then
        for _, shop in { "SeedShop", "GearShop" } do
            local items = stockRoot:FindFirstChild(shop) and stockRoot[shop]:FindFirstChild("Items")
            if items then
                items.ChildAdded:Connect(function() task.defer(refreshLive) end)
                for _, ch in items:GetChildren() do
                    if ch:IsA("ValueBase") then ch.Changed:Connect(function() task.defer(refreshLive) end) end
                end
            end
        end
    end
    task.spawn(function()
        while true do
            refreshPredict()
            refreshWeatherTab()
            task.wait(1)
        end
    end)
    while task.wait(2) do refreshLive() end
end)

