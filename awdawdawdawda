        fruitEspFolder = Instance.new("Folder")
        fruitEspFolder.Name = "NTMT_FruitESP"
        fruitEspFolder.Parent = Services.Workspace
    end
    return fruitEspFolder
end

function updateFruitEsp()
    if not genv.ftgs_FruitESP then
        clearFruitEsp()
        return
    end
    local targets = findTopValueFruits(10)
    if #targets == 0 then
        clearFruitEsp()
        return
    end
    ensureFruitEspFolder()
    clearFruitEsp()
    for i, t in targets do
        local hl = Instance.new("Highlight")
        hl.Name = "NTMT_FruitESP_" .. i
        hl.Adornee = t.fruit
        hl.FillColor = Color3.fromRGB(255, 60, 200)
        hl.OutlineColor = Color3.fromRGB(255, 255, 80)
        hl.FillTransparency = 0.35
        hl.OutlineTransparency = 0
        hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        hl.Parent = fruitEspFolder
        local bb = Instance.new("BillboardGui")
        bb.Name = "NTMT_ValueTag"
        bb.Adornee = t.part
        bb.Size = UDim2.fromOffset(110, 30)
