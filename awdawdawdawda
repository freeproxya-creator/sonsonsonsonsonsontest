function equipSeedForPlant(seedName)
    local tool = findSeedToolByName(seedName)
    if not tool then return nil end
    local hum = getHumanoid()
    local bp = LocalPlayer:FindFirstChild("Backpack")
    if hum then
        local equipped = hum:FindFirstChildOfClass("Tool")
        if equipped and equipped ~= tool then
            xpcall(function() hum:UnequipTools() end, noopErr)
            task.wait(0.06)
        end
        if tool.Parent == bp then
            xpcall(function() hum:EquipTool(tool) end, noopErr)
        elseif tool.Parent ~= LocalPlayer.Character then
            if bp then tool.Parent = bp end
            task.wait(0.04)
            tool = findSeedToolByName(seedName)
            if tool and tool.Parent == bp then xpcall(function() hum:EquipTool(tool) end, noopErr) end
        end
        for _ = 1, 10 do
            tool = findSeedToolByName(seedName)
            if tool and tool.Parent == LocalPlayer.Character then return tool end
            task.wait(0.04)
        end
    end
    return findSeedToolByName(seedName) or tool
end

