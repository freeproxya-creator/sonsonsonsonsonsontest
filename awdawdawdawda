        end
        if prompt then return prompt end
        prompt = hp:FindFirstChildWhichIsA("ProximityPrompt")
        if prompt then return prompt end
    end
    for _, desc in fruit:GetDescendants() do
        if desc:IsA("ProximityPrompt") then
