    if not hum then return end
    hum.UseJumpPower = true
    if hum.WalkSpeed ~= desiredWalkSpeed then hum.WalkSpeed = desiredWalkSpeed end
    if hum.JumpPower ~= desiredJumpPower then hum.JumpPower = desiredJumpPower end
end

function applyMovementBypass(_dt)
    if not genv.ftgs_BypassMovement then return end
    if genv.ftgs_FakeLag or movementBypass or gardenActionLock or isCatchingPet or stealBusy or collectingMutation then return end
    local hum = getHumanoid()
    local hrp = getRoot()
    if not hum or not hrp then return end
    applyMovement()
    if hum.PlatformStand then hum.PlatformStand = false end
    local dir = hum.MoveDirection
    if dir.Magnitude <= 0.05 then return end
    local flat = Vector3.new(dir.X, 0, dir.Z)
    if flat.Magnitude <= 0.01 then return end
    flat = flat.Unit
    local speed = desiredWalkSpeed
    local vy = hrp.AssemblyLinearVelocity.Y
    hrp.AssemblyLinearVelocity = Vector3.new(flat.X * speed, vy, flat.Z * speed)
    hrp.AssemblyAngularVelocity = Vector3.zero
end

function setupAntiKnockbackChar(char)
    if antiKbConn then antiKbConn:Disconnect() antiKbConn = nil end
    if not char then return end
    local hrp = char:WaitForChild("HumanoidRootPart", 8)
    if not hrp then return end
    local function dampenKnockback(v)
        if not genv.ftgs_AntiHit then return end
        if v:IsA("BodyVelocity") then
            v.Velocity = v.Velocity * ANTI_KB_PERCENT
        elseif v:IsA("LinearVelocity") then
            v.VectorVelocity = v.VectorVelocity * ANTI_KB_PERCENT
        elseif v:IsA("VectorForce") then
            v.Force = v.Force * ANTI_KB_PERCENT
        elseif v:IsA("BodyForce") then
            v.Force = v.Force * ANTI_KB_PERCENT
        end
    end
    for _, child in hrp:GetChildren() do dampenKnockback(child) end
    antiKbConn = hrp.ChildAdded:Connect(dampenKnockback)
end

