function buildFreePlantSpots(plot)
    local grid, free, seen = {}, {}, {}
    for _, area in getPlotPlantAreas(plot) do
        local cf, sz = area.CFrame, area.Size
        local topY = area.Position.Y + sz.Y / 2 + 0.3
        local hx, hz = sz.X / 2 - 3, sz.Z / 2 - 3
        local nx, nz = math.floor((2 * hx) / PLANT_GRID_STEP), math.floor((2 * hz) / PLANT_GRID_STEP)
        for ix = 0, nx do
            for iz = 0, nz do
                local w = (cf * CFrame.new(-hx + ix * PLANT_GRID_STEP, 0, -hz + iz * PLANT_GRID_STEP)).Position
                local key = math.floor(w.X / 4 + 0.5) .. "," .. math.floor(w.Z / 4 + 0.5)
                if not seen[key] then
                    seen[key] = true
                    grid[#grid + 1] = Vector3.new(w.X, topY, w.Z)
                end
            end
        end
    end
    local occ = {}
    local pf = plot:FindFirstChild("Plants")
    if pf then
        for _, pl in pf:GetChildren() do
            local ok, pv = pcall(function() return pl:GetPivot().Position end)
            if ok then occ[#occ + 1] = pv end
        end
    end
    for _, pos in grid do
        local clear = true
        for _, o in occ do
            if (Vector3.new(o.X, 0, o.Z) - Vector3.new(pos.X, 0, pos.Z)).Magnitude < PLANT_GRID_MIN_DIST then
                clear = false
                break
            end
        end
        if clear then free[#free + 1] = pos end
    end
    return free
end
