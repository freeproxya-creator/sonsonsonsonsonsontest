function loadConfig()
    if type(genv.ftgs_webhookUrl) == "string" and genv.ftgs_webhookUrl ~= "" then webhookUrl = genv.ftgs_webhookUrl end
    if type(genv.ftgs_webhookPetShopUrl) == "string" then webhookPetShopUrl = genv.ftgs_webhookPetShopUrl end
    if type(genv.ftgs_webhookIntervalMin) == "number" then webhookIntervalMin = genv.ftgs_webhookIntervalMin end
    if type(genv.ftgs_uiTheme) == "string" then selectedUITheme = genv.ftgs_uiTheme end
    if not (readfile and isfile and isfile(CONFIG_FILE)) then return end
    local ok, data = xpcall(function() return Services.HttpService:JSONDecode(readfile(CONFIG_FILE)) end, noopErr)
    if not ok or type(data) ~= "table" then return end
    if type(data.webhookUrl) == "string" then webhookUrl = data.webhookUrl end
    if type(data.webhookPetShopUrl) == "string" then webhookPetShopUrl = data.webhookPetShopUrl end
    webhookIntervalMin = tonumber(data.webhookIntervalMin) or webhookIntervalMin
    if data.autoWebhook ~= nil then genv.ftgs_AutoWebhook = data.autoWebhook == true end
    if type(data.uiTheme) == "string" then selectedUITheme = data.uiTheme end
    if type(data.mailUsername) == "string" then mailUsername = data.mailUsername end
    if type(data.mailMessage) == "string" and data.mailMessage ~= "" then mailMessage = data.mailMessage end
    if type(data.mailSeedName) == "string" then mailSeedName = data.mailSeedName end
    if type(data.mailGearName) == "string" then mailGearName = data.mailGearName end
    mailSeedAmount = tonumber(data.mailSeedAmount) or mailSeedAmount
    mailGearAmount = tonumber(data.mailGearAmount) or mailGearAmount
    if type(data.BoughtSeeds) == "table" then BoughtSeeds = data.BoughtSeeds end
    if type(data.BoughtGears) == "table" then BoughtGears = data.BoughtGears end
    if type(data.BoughtPets) == "table" then BoughtPets = data.BoughtPets end
    if type(data.StolenFruits) == "table" then StolenFruits = data.StolenFruits end
    if data.autoExecute ~= nil then genv.ftgs_AutoExecute = data.autoExecute == true end
    if data.fixLag ~= nil then genv.ftgs_FixLag = data.fixLag == true end
    if data.fakeLag ~= nil then genv.ftgs_FakeLag = data.fakeLag == true end
    fakeLagDelay = 2
    if type(data.translateLanguage) == "string" then translateLanguage = data.translateLanguage end
    if type(data.selectedBgTheme) == "string" then selectedBgTheme = data.selectedBgTheme end
    visualMoneyAmount = tonumber(data.visualMoneyAmount) or visualMoneyAmount
    if visualMoneyAmount == 0 then visualMoneyAmount = nil end
    if type(data.privateServerCode) == "string" then privateServerCode = data.privateServerCode end
    if type(data.selectedStealFruits) == "table" then
        table.clear(selectedStealFruits)
        for k, v in data.selectedStealFruits do
            if type(v) == "string" then selectedStealFruits[v] = true
            elseif v then selectedStealFruits[k] = true end
        end
    end
    if type(data.scriptUrl) == "string" and data.scriptUrl ~= "" then genv.NTMT_SCRIPT_URL = data.scriptUrl end
    if data.hubKeyUnlocked == true then hubKeyUnlocked = true end
    totalPlaySeconds = tonumber(data.totalPlaySeconds) or totalPlaySeconds
    sessionStart = os.time()
end
