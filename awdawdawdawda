function evalShopPredictItem(item, anchor, period, count, nowT)
    if not item or type(item.q) ~= "table" then return { cur = nil, nxt = nil } end
    count = count or #item.q
    period = period or 300
    anchor = anchor or 0
    nowT = nowT or os.time()
    local idx = math.floor((nowT - anchor) / period)
    local cur, nxt = nil, nil
    if idx >= 0 and idx < count and (item.q[idx + 1] or 0) > 0 then
        cur = { t = anchor + idx * period, q = item.q[idx + 1] }
    end
    for k = math.max(idx + 1, 0), count - 1 do
        if (item.q[k + 1] or 0) > 0 then
            nxt = { t = anchor + k * period, q = item.q[k + 1] }
            break
        end
    end
    return { cur = cur, nxt = nxt }
end

function buildShopPredictLine(item, anchor, period, count, nowT)
    local ev = evalShopPredictItem(item, anchor, period, count, nowT)
    local qty, eta = 0, nil
    if ev.nxt then
        qty = ev.nxt.q
        eta = math.max(0, ev.nxt.t - nowT)
    end
    local etaStr = eta and formatEtaLong(eta) or "—"
    return string.format("%s | x%d | %s | %s", shopPredictDisplayName(item.name), qty, etaStr, formatCompactNumber(item.price or 0))
end

