function getRoot()
    local c = LocalPlayer.Character
    return c and c:FindFirstChild("HumanoidRootPart")
end

function getHumanoid()
    local c = LocalPlayer.Character
    return c and c:FindFirstChildOfClass("Humanoid")
end

function formatDuration(totalSec)
    totalSec = math.max(0, math.floor(totalSec))
    return string.format("%dh %02dm %02ds", math.floor(totalSec / 3600), math.floor((totalSec % 3600) / 60), totalSec % 60)
end

function timeAgo(ts) return formatDuration(os.time() - ts) .. " ago" end

function getSheckles()
    local ls = LocalPlayer:FindFirstChild("leaderstats")
    local s = ls and ls:FindFirstChild("Sheckles")
    if s then return s.Value end
    if PlayerReplica and PlayerReplica.Data then return PlayerReplica.Data.Sheckles or 0 end
    return 0
end

function getFruitCount() return LocalPlayer:GetAttribute("FruitCount") or 0 end
function getMaxFruitCapacity() return LocalPlayer:GetAttribute("MaxFruitCapacity") or 100 end
function isInventoryFull() return getFruitCount() >= getMaxFruitCapacity() end

function cachePlantPositions(plot)
    table.clear(savedPlantPositions)
    if not plot then return end
    local visual = plot:FindFirstChild("Visual")
    if not visual then return end
    for _, col in visual:GetChildren() do
        if col.Name:match("^PlantAreaColumn") then
            for _, part in col:GetChildren() do
                if part:IsA("BasePart") then savedPlantPositions[#savedPlantPositions + 1] = part.Position end
            end
        end
    end
end

function refreshPlantAreas()
    table.clear(plantAreas)
    for _, pos in savedPlantPositions do plantAreas[#plantAreas + 1] = pos end
    if #plantAreas == 0 and savedPlotCenter then
        local step, hx, hz = 4, savedPlotSize.X / 2 - 2, savedPlotSize.Z / 2 - 2
        for x = -hx, hx, step do
            for z = -hz, hz, step do
                plantAreas[#plantAreas + 1] = Vector3.new(savedPlotCenter.X + x, savedPlotCenter.Y, savedPlotCenter.Z + z)
            end
        end
    end
end

function updatePlotCenterFromPlot(plot)
    if not plot then return end
    local psr = plot:FindFirstChild("PlotSizeReference")
    if psr and psr:IsA("BasePart") then
        savedPlotCenter, savedPlotSize = psr.Position, psr.Size
