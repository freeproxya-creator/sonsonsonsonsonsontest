    function compat:SetTheme(_name)
        if type(lib.SetTheme) == "function" then
            xpcall(function() lib:SetTheme("Darker") end, noopErr)
        end
    end
    return compat
end

local WindUI
local function loadRedzUI()
    local function finishWithLib(lib)
        if type(lib) ~= "table" or type(lib.CreateWindow) ~= "function" then return false end
        WindUI = lib
        return true
    end

    if type(loadstring) ~= "function" and type(load) ~= "function" then
        hubWarn("loadstring missing — using built-in UI")
        return finishWithLib(createBuiltinWindUI())
    end

    local body = universalHttpGet(REDZ_UI_URL)
    if type(body) ~= "string" or #body < 1000 then
        hubWarn("redz-V5 download failed — using built-in UI")
        return finishWithLib(createBuiltinWindUI())
    end

    local chunk
    if type(loadstring) == "function" then
        chunk = loadstring(body, "redz-V5")
    elseif type(load) == "function" then
        chunk = load(body, "redz-V5", "t")
    end
    if type(chunk) ~= "function" then
        hubWarn("redz-V5 compile failed — using built-in UI")
        return finishWithLib(createBuiltinWindUI())
    end

    local ok, lib = xpcall(chunk, function(err)
        if debug and debug.traceback then return debug.traceback(tostring(err), 2) end
        return tostring(err)
    end)
    if not ok or type(lib) ~= "table" or type(lib.MakeWindow) ~= "function" then
        hubWarn("redz-V5 runtime failed — using built-in UI:", tostring(lib))
        return finishWithLib(createBuiltinWindUI())
    end

    RedzLib = lib
    WindUI = createRedzCompatLib(lib)
    print("[NTMT HUB] redz-V5 UI loaded OK")
    return true
end


