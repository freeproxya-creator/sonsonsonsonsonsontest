local function wrapTextBox(obj)
    local wrapped = {
        TEXTBOX = obj and obj.TEXTBOX,
        GetValue = function()
            if obj and obj.TEXTBOX then return obj.TEXTBOX.Text or "" end
            return ""
        end,
        Get = function()
            return wrapped.GetValue()
        end,
    }
    if obj and obj.TEXTBOX then
        wrapped.Value = obj.TEXTBOX.Text
    end
    return wrapped
end

local function wrapTab(tab)
    local wrapper = {}
    function wrapper:Section(cfg)
        tab:AddSection(type(cfg) == "table" and cfg.Title or cfg)
    end
    function wrapper:Toggle(cfg)
        return tab:AddToggle({
            Title = cfg.Title,
            Description = cfg.Desc or cfg.Description,
            Default = cfg.Default,
            Callback = cfg.Callback,
        })
    end
    function wrapper:Button(cfg)
        return tab:AddButton({
            Title = cfg.Title,
            Description = cfg.Desc or cfg.Description,
            Callback = cfg.Callback,
            Debounce = cfg.Debounce or cfg.Cooldown,
        })
    end
    function wrapper:Input(cfg)
        return wrapTextBox(tab:AddTextBox({
            Title = cfg.Title,
            Default = cfg.Value,
            Placeholder = cfg.Placeholder or cfg.PlaceholderText,
            ClearOnFocus = cfg.ClearOnFocus,
            Callback = cfg.Callback,
        }))
    end
    function wrapper:Slider(cfg)
        local vmin = cfg.Value and cfg.Value.Min or cfg.Min or 0
        local vmax = cfg.Value and cfg.Value.Max or cfg.Max or 100
        local vdef = cfg.Value and cfg.Value.Default or cfg.Default or vmin
        return tab:AddSlider({
            Title = cfg.Title,
            Description = cfg.Desc or cfg.Description,
            Min = vmin,
            Max = vmax,
            Increment = cfg.Step or cfg.Increment or 1,
            Default = vdef,
            Callback = cfg.Callback,
        })
    end
    function wrapper:Dropdown(cfg)
        local multi = cfg.Multi or cfg.MultiSelect
        local default = cfg.Value
        if multi and type(default) == "string" then
            default = { default }
        end
        return tab:AddDropdown({
            Title = cfg.Title,
            Description = cfg.Desc or cfg.Description,
            Options = cfg.Values or cfg.Options,
            Default = default,
            MultiSelect = multi,
            Callback = cfg.Callback,
        })
    end
    function wrapper:Paragraph(cfg)
        return wrapParagraph(tab:AddParagraph(cfg.Title or "", cfg.Desc or cfg.Description or cfg.Content or ""))
    end
    return wrapper
end

