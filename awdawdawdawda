function clearGodMode(char)
    if godModeHealthConn then godModeHealthConn:Disconnect() godModeHealthConn = nil end
    if godModeStateConn then godModeStateConn:Disconnect() godModeStateConn = nil end
    godModeBoundHum = nil
    local hum = (char or LocalPlayer.Character) and (char or LocalPlayer.Character):FindFirstChildOfClass("Humanoid")
    if hum then
        pcall(function() hum:SetStateEnabled(Enum.HumanoidStateType.Dead, true) end)
        if hum.MaxHealth > 1000 then
            hum.MaxHealth = 100
            hum.Health = math.min(hum.Health, hum.MaxHealth)
        end
    end
end

function applyGodMode(char)
    if not genv.ftgs_GodMode or not char then
        clearGodMode(char)
        return
    end
    local hum = char:FindFirstChildOfClass("Humanoid") or char:WaitForChild("Humanoid", 5)
    if not hum then return end
    if godModeBoundHum == hum and godModeHealthConn then return end
    clearGodMode(char)
    pcall(function()
        hum:SetStateEnabled(Enum.HumanoidStateType.Dead, false)
        hum.BreakJointsOnDeath = false
    end)
    hum.MaxHealth = 999999999
    hum.Health = hum.MaxHealth
    godModeBoundHum = hum
    godModeHealthConn = hum.HealthChanged:Connect(function(h)
        if not genv.ftgs_GodMode then return end
        if h < hum.MaxHealth then hum.Health = hum.MaxHealth end
    end)
    godModeStateConn = hum.StateChanged:Connect(function(_, new)
        if not genv.ftgs_GodMode then return end
        if new == Enum.HumanoidStateType.Dead then
            pcall(function() hum:ChangeState(Enum.HumanoidStateType.GettingUp) end)
            hum.Health = hum.MaxHealth
        end
    end)
end

function maintainGodMode()
    if not genv.ftgs_GodMode then return end
    local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
    if not hum then return end
    if godModeBoundHum ~= hum then applyGodMode(LocalPlayer.Character) return end
    if hum.MaxHealth < 999999999 then hum.MaxHealth = 999999999 end
    if hum.Health < hum.MaxHealth then hum.Health = hum.MaxHealth end
end

