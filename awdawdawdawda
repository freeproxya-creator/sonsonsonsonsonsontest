function readShopRestockToken()
    local tokens = {}
    for _, folder in { SeedShopFolder, GearShopFolder, StockValuesRoot } do
        if folder then
            for _, key in { "RestockToken", "RestockId", "StockGeneration", "Generation", "RestockTime" } do
                local val = folder:GetAttribute(key)
                if val ~= nil then tokens[#tokens + 1] = key .. ":" .. tostring(val) end
            end
        end
    end
    table.sort(tokens)
    return table.concat(tokens, "|")
end

