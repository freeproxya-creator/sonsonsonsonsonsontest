function trackSeedBuy(name)
    local p = getSeedPrice(name)
    local e = BoughtSeeds[name]
    if e then e.amount += 1 else BoughtSeeds[name] = { amount = 1, price = p } end
end
function trackGearBuy(name)
    local p = getGearPrice(name)
    local e = BoughtGears[name]
    if e then e.amount += 1 else BoughtGears[name] = { amount = 1, price = p } end
end
function trackPetBuy(name, price)
    local e = BoughtPets[name]
    if e then e.amount += 1 else BoughtPets[name] = { amount = 1, price = price or 0 } end
end

function isDataReady(data)
    if type(data) ~= "table" then return false end
    local maxAge = data.MaxAge or 0
    local age = data.Age or 0
    return maxAge <= 0 or age >= maxAge
end

function isGrownEntity(entity)
    if not entity then return false end
    local maxAge = entity:GetAttribute("MaxAge")
    local currentAge = entity:GetAttribute("Age")
    if maxAge == nil or currentAge == nil then return false end
    return currentAge >= maxAge
end

function collectPhysicalHarvestables()
    refreshOwnerPlot()
    local list = {}
    local pf = OwnerPlot and OwnerPlot:FindFirstChild("Plants")
    if not pf then return list end
    for _, plant in pf:GetChildren() do
        local parentSeed = plant:GetAttribute("SeedName") or plant:GetAttribute("PlantName") or plant:GetAttribute("CorePartName")
        local plantData = { SeedName = parentSeed, PlantName = parentSeed }
        local fruitsFolder = plant:FindFirstChild("Fruits")
        if fruitsFolder then
            for _, fruit in fruitsFolder:GetChildren() do
                if fruit:IsA("Model") and isGrownEntity(fruit) and shouldHarvestTarget(plantData, { SeedName = parentSeed }) then
                    list[#list + 1] = fruit
                end
            end
        elseif plant:IsA("Model") and isGrownEntity(plant) and shouldHarvestTarget(plantData, nil) then
            list[#list + 1] = plant
        end
    end
    return list
end

function tryHarvestBestTick()
    if not genv.ftgs_AutoHarvestBest then return end
    refreshOwnerPlot()
    if not OwnerPlot then return end
    local bestEntity, bestVal
    for _, entity in collectPhysicalHarvestables() do
        local val = calculateStealValue(entity) or 0
        if not bestEntity or val > bestVal then
            bestEntity, bestVal = entity, val
        end
    end
    if not bestEntity then return end
    local plantId = bestEntity:GetAttribute("PlantId")
    local fruitId = bestEntity:GetAttribute("FruitId") or ""
    if not plantId then
        local parentPlant = bestEntity:FindFirstAncestorWhichIsA("Model")
        if parentPlant and parentPlant.Parent and parentPlant.Parent.Name == "Plants" then
            plantId = parentPlant:GetAttribute("PlantId")
        end
    end
    if plantId then
        safeNetCall(Net.Garden and Net.Garden.CollectFruit, plantId, fruitId)
    end
end

function isPhysicalFruitRipe(fruit, plant)
    if not fruit then return false end
    local maxAge = fruit:GetAttribute("MaxAge") or (plant and plant:GetAttribute("MaxAge"))
    local age = fruit:GetAttribute("Age") or fruit:GetAttribute("SizeMulti")
    if type(maxAge) == "number" and maxAge > 0 and type(age) == "number" then
        return age >= maxAge
    end
    local prompt = fruit:FindFirstChildWhichIsA("ProximityPrompt", true)
    return prompt ~= nil and getStealPrompt(fruit) == nil
end

function findBestHarvestablePhysical()
    refreshOwnerPlot()
    local pf = OwnerPlot and OwnerPlot:FindFirstChild("Plants")
    if not pf then return nil end
    local best
    for _, plant in pf:GetChildren() do
        local plantId = plant:GetAttribute("PlantId") or plant:GetAttribute("PlantID") or plant.Name
        local plantData = trackedPlants[plantId] or {
            SeedName = plant:GetAttribute("SeedName") or plant:GetAttribute("PlantName"),
            PlantName = plant:GetAttribute("PlantName") or plant:GetAttribute("SeedName"),
        }
        local fruitsFolder = plant:FindFirstChild("Fruits")
        if fruitsFolder then
            for _, fruit in fruitsFolder:GetChildren() do
                if not isPhysicalFruitRipe(fruit, plant) then continue end
                if not shouldHarvestTarget(plantData, { SeedName = plantData.SeedName }) then continue end
                local fruitId = fruit:GetAttribute("FruitId") or fruit:GetAttribute("FruitID") or fruit.Name
                local val = calculateStealValue(fruit) or 0
                if not best or val > best.value then
                    best = { plantId = plantId, fruitId = fruitId, value = val }
                end
            end
        end
        if isPhysicalFruitRipe(plant, nil) and shouldHarvestTarget(plantData, nil) then
            local val = 0
            if not best or val > best.value then
                best = { plantId = plantId, fruitId = "", value = val }
            end
        end
    end
    return best
end

function findBestHarvestableInGarden()
    local best
    for plantId, plantData in pairs(trackedPlants) do
        if type(plantData) ~= "table" then continue end
        local fruits = plantData.Fruits
        if type(fruits) == "table" then
            for fruitId, fruitData in pairs(fruits) do
                if isDataReady(fruitData) and shouldHarvestTarget(plantData, fruitData) then
                    local val = 0
                    local ok, v = xpcall(
                        FruitValueCalc,
                        noopErr,
                        getPlantSeedName(fruitData),
                        fruitData.SizeMulti or fruitData.Age,
                        fruitData.Mutation,
                        LocalPlayer,
                        1
                    )
                    if ok then val = v or 0 end
                    if not best or val > best.value then
                        best = { plantId = plantId, fruitId = fruitId, value = val }
                    end
                end
            end
        end
        if isDataReady(plantData) and shouldHarvestTarget(plantData, nil) then
            local val = 0
            local ok, v = xpcall(
                FruitValueCalc,
                noopErr,
                getPlantSeedName(plantData),
                plantData.SizeMulti or plantData.Age,
                plantData.Mutation,
                LocalPlayer,
                1
            )
            if ok then val = v or 0 end
            if not best or val > best.value then
                best = { plantId = plantId, fruitId = "", value = val }
            end
        end
    end
    if best then return best end
    return findBestHarvestablePhysical()
end

function cleanupFiredSetIfNeeded(now)
    now = now or os.clock()
    if now - lastFiredCleanup < 5 then return end
    lastFiredCleanup = now
    for key, time in pairs(firedSet) do
        if now - time > 30 then firedSet[key] = nil end
    end
end

function tryHarvestTick()
    if not autoHarvestOn() then return end
    local now = os.clock()
    local n = 0

    if autoHarvestOn() then
        for plantId, plantData in pairs(trackedPlants) do
            if type(plantData) ~= "table" then continue end
            local fruits = plantData.Fruits
            if type(fruits) == "table" then
                for fruitId, fruitData in pairs(fruits) do
                    if isDataReady(fruitData) and shouldHarvestTarget(plantData, fruitData) then
                        local key = tostring(plantId) .. "|" .. tostring(fruitId)
                        if not firedSet[key] and n < HARVEST_BATCH then
                            safeNetCall(Net.Garden and Net.Garden.CollectFruit, plantId, fruitId)
                            firedSet[key] = now
                            n += 1
                        end
                    end
                end
            end
            if n >= HARVEST_BATCH then break end
            if isDataReady(plantData) and shouldHarvestTarget(plantData, nil) then
                local key = tostring(plantId) .. "|_plant"
                if not firedSet[key] and n < HARVEST_BATCH then
                    safeNetCall(Net.Garden and Net.Garden.CollectFruit, plantId, "")
                    firedSet[key] = now
                    n += 1
                end
            end
            if n >= HARVEST_BATCH then break end
        end
    end

    cleanupFiredSetIfNeeded(now)
end

