function clearFruitEsp()
    for _, item in fruitEspItems do
        if item.highlight then item.highlight:Destroy() end
        if item.billboard then item.billboard:Destroy() end
    end
    fruitEspItems = {}
end

function findTopValueFruits(limit)
    limit = limit or 10
    local list = {}
    if not Gardens then return list end
    for _, plot in Gardens:GetChildren() do
        local plants = plot:FindFirstChild("Plants")
        if not plants then continue end
        for _, plant in plants:GetChildren() do
            local fruits = plant:FindFirstChild("Fruits")
            local scan = fruits and fruits:GetChildren() or { plant }
            for _, fr in scan do
                local part = fr:IsA("BasePart") and fr or fr:FindFirstChildWhichIsA("BasePart", true)
                if part then
                    list[#list + 1] = { fruit = fr, part = part, value = calculateStealValue(fr), plot = plot.Name }
                end
            end
        end
    end
    table.sort(list, function(a, b) return (a.value or 0) > (b.value or 0) end)
    local out = {}
    for i = 1, math.min(limit, #list) do out[i] = list[i] end
    return out
end

