function stopFakeLag()
    fakeLagThreadId += 1
    if fakeLagPreConn then fakeLagPreConn:Disconnect() fakeLagPreConn = nil end
    if fakeLagPostConn then fakeLagPostConn:Disconnect() fakeLagPostConn = nil end
    fakeLagPendingCF = nil
    fakeLagReplicatedCF = nil
end

function setFakeLag(on, delay)
    genv.ftgs_FakeLag = on == true
    fakeLagDelay = 2
    if delay ~= nil then fakeLagDelay = math.max(0.05, tonumber(delay) or fakeLagDelay) end
    saveConfig()
    stopFakeLag()
    if not genv.ftgs_FakeLag then return end
    local tid = fakeLagThreadId
    task.spawn(function()
        while genv.ftgs_FakeLag and tid == fakeLagThreadId do
            task.wait(fakeLagDelay)
            if fakeLagPendingCF then fakeLagReplicatedCF = fakeLagPendingCF end
        end
    end)
    fakeLagPostConn = Services.RunService.Heartbeat:Connect(function()
        if not genv.ftgs_FakeLag or movementBypass or gardenActionLock or stealBusy or isCatchingPet then return end
        if genv.ftgs_BypassMovement and desiredWalkSpeed > 16 then return end
        local hrp = getRoot()
        if not hrp then return end
        fakeLagPendingCF = hrp.CFrame
        if fakeLagReplicatedCF then
            hrp.CFrame = fakeLagReplicatedCF
        else
            fakeLagReplicatedCF = hrp.CFrame
        end
    end)
    fakeLagPreConn = Services.RunService.RenderStepped:Connect(function()
        if not genv.ftgs_FakeLag or movementBypass or gardenActionLock or stealBusy or isCatchingPet then return end
        if genv.ftgs_BypassMovement and desiredWalkSpeed > 16 then return end
        local hrp = getRoot()
        if hrp and fakeLagPendingCF then hrp.CFrame = fakeLagPendingCF end
    end)
end

function cacheScriptSourceForAutoExec()
    if type(genv.__NTMT_SOURCE) == "string" and #genv.__NTMT_SOURCE > 200 then return end
    if not (readfile and isfile) then return end
    for _, path in NTMT_EXEC_PATHS do
        if isfile(path) then
            local ok, src = xpcall(readfile, noopErr, path)
            if ok and type(src) == "string" and #src > 200 then
                genv.__NTMT_SOURCE = src
                return
            end
        end
    end
end

function buildAutoExecutePayload()
    if type(genv.NTMT_SCRIPT_URL) == "string" and genv.NTMT_SCRIPT_URL ~= "" then
        return string.format([[
task.defer(function()
    local ok, src = pcall(function() return game:HttpGet(%q) end)
    if ok and type(src) == "string" then loadstring(src, "NTMT")() end
end)
]], genv.NTMT_SCRIPT_URL)
    end
    if type(genv.__NTMT_SOURCE) == "string" and #genv.__NTMT_SOURCE > 200 then
        genv.__NTMT_SOURCE_B64 = genv.__NTMT_SOURCE
        return [[
task.defer(function()
    local s = getgenv().__NTMT_SOURCE_B64 or getgenv().__NTMT_SOURCE
    if type(s) == "string" then loadstring(s, "NTMT")() end
end)
]]
    end
    if readfile and isfile then
        for _, path in NTMT_EXEC_PATHS do
            if isfile(path) then
                return string.format([[
task.defer(function()
    if readfile and isfile(%q) then loadstring(readfile(%q), "NTMT")() end
end)
]], path, path)
            end
        end
    end
    return nil
end

function setupAutoExecute()
    local queueFn = (syn and syn.queue_on_teleport) or queue_on_teleport or (fluxus and fluxus.queue_on_teleport)
    if type(queueFn) ~= "function" then return end
    cacheScriptSourceForAutoExec()
    local payload = buildAutoExecutePayload()
    if not payload then return end
    LocalPlayer.OnTeleport:Connect(function(state)
        if not genv.ftgs_AutoExecute or autoExecuteQueued then return end
        if state == Enum.TeleportState.Started or state == Enum.TeleportState.InProgress then
            autoExecuteQueued = true
            xpcall(function() queueFn(payload) end, noopErr)
        end
    end)
end

