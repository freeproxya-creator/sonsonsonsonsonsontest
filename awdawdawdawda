function scanDropPromptsInto(container, out, hrpPos)
    if not container then return end
    for _, item in container:GetDescendants() do
        if not item:IsA("ProximityPrompt") then continue end
        local action = (item.ActionText or ""):lower()
        local obj = (item.ObjectText or ""):lower()
        if not (action:find("pick") or action:find("collect") or action:find("grab") or obj:find("drop")) then continue end
        local parent = item.Parent
        if not parent then continue end
        local part = parent:IsA("BasePart") and parent or parent:FindFirstChildWhichIsA("BasePart", true)
        if not part then continue end
        if hrpPos and (part.Position - hrpPos).Magnitude > DROP_COLLECT_RADIUS then continue end
        out[#out + 1] = { prompt = item, part = part, dist = hrpPos and (part.Position - hrpPos).Magnitude or 0 }
    end
end

function rebuildDropPromptCache()
    dropPromptCache = {}
    local hrp = getRoot()
    local hrpPos = hrp and hrp.Position
    local roots = {}
    local map = Services.Workspace:FindFirstChild("Map")
    if map then
        for _, name in { "ItemDrops", "Drops", "Collectibles", "SeedPackSpawns" } do
            local folder = map:FindFirstChild(name)
            if folder then roots[#roots + 1] = folder end
        end
    end
    for _, name in { "Drops", "ItemDrops" } do
        local folder = Services.Workspace:FindFirstChild(name)
        if folder then roots[#roots + 1] = folder end
    end
    if OwnerPlot then roots[#roots + 1] = OwnerPlot end
    for _, root in roots do scanDropPromptsInto(root, dropPromptCache, hrpPos) end
    table.sort(dropPromptCache, function(a, b) return a.dist < b.dist end)
    lastDropScan = os.clock()
end

function findNearestDropPrompt()
    local hrp = getRoot()
    if not hrp then return nil end
    if os.clock() - lastDropScan > DROP_SCAN_INTERVAL then rebuildDropPromptCache() end
    if #dropPromptCache == 0 then return nil end
    local entry = dropPromptCache[1]
    if not entry or not entry.prompt or not entry.prompt.Parent then
        rebuildDropPromptCache()
        entry = dropPromptCache[1]
    end
    if not entry then return nil end
    return { prompt = entry.prompt, part = entry.part }
end

