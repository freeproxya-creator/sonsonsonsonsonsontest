function tryAutoPlant()
    if not autoPlantOn() then return end
    if plantingBusy then return end
    if not OwnerPlot then refreshOwnerPlot() end
    if not OwnerPlot then return end

    local kaitun = ftgsOn("ftgs_Kaitun_AutoPlantAll")
    if kaitun then applyKaitunPlantRaritiesToSelection() end
    if not setHasAny(selectedPlantSeeds) then return end

    if not isInGardenActionRange() then
        if savedPlotCenter then
            tpInstant(savedPlotCenter)
            task.wait(0.06)
        end
        if not isInGardenActionRange() then return end
    end

    local batch = kaitun and KAITUN_PLANT_BATCH or PLANT_BATCH
    plantingBusy = true
    local planted = 0

    for _ = 1, batch do
        if not autoPlantOn() then break end
        if os.clock() - lastPlant < COOLDOWN.Plant then break end
        local seedName, tool = kaitun and pickKaitunPlantSeed() or pickNextPlantSeed()
        if not seedName then break end
        local pos = getFreePlantSpot(planted == 0)
        if not pos then break end
        tool = equipSeedForPlant(seedName)
        if not tool then break end
        lastPlant = os.clock()
        safeNetCall(Net.Plant and Net.Plant.PlantSeed, pos, seedName, tool, OwnerPlot)
        if type(tool.Activate) == "function" then xpcall(function() tool:Activate() end, noopErr) end
        consumeFreePlantSpot()
        planted += 1
    end

    if planted > 0 then
        cachedOccupied = nil
        lastOccupiedScan = 0
    end
    plantingBusy = false
end

