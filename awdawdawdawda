function initFavoriteRemotes()
    if favoriteRemote then return favoriteRemote end
    local function isRemote(node)
        return node and (type(node.Fire) == "function" or type(node.FireServer) == "function" or type(node.InvokeServer) == "function" or type(node.Invoke) == "function")
    end
    local function tryPath(path)
        local node = Net
        for seg in string.gmatch(path, "[^.]+") do
            node = node and node[seg]
        end
        if isRemote(node) then return node, path end
    end
    if Net and type(Net.Inventory) == "table" then
        for k, v in Net.Inventory do
            if type(k) == "string" and string.find(string.lower(k), "fav", 1, true) and isRemote(v) then
                favoriteRemote = v
                favoriteRemotePath = "Inventory." .. k
                favoriteRemoteMode = string.find(string.lower(k), "toggle", 1, true) and "toggle" or "set"
                return favoriteRemote
            end
        end
    end
    local paths = {
        "Inventory.ToggleHarvestedFruitFavorite",
        "Inventory.SetHarvestedFruitFavorite",
        "Inventory.ToggleFavorite",
        "Inventory.SetFavorite",
        "Inventory.FavoriteItem",
        "Inventory.SetItemFavorite",
        "Inventory.ToggleItemFavorite",
        "Inventory.SetItemFavoriteState",
        "Hotbar.ToggleFavorite",
        "Hotbar.SetFavorite",
        "UI.ToggleFavorite",
        "Favorites.ToggleHarvestedFruit",
        "Favorites.SetHarvestedFruitFavorite",
        "Favorites.Toggle",
        "Favorites.SetFavorite",
    }
    for _, path in paths do
        local remote, full = tryPath(path)
        if remote then
            favoriteRemote = remote
            favoriteRemotePath = full
            favoriteRemoteMode = string.find(string.lower(full), "toggle", 1, true) and "toggle" or "set"
            return remote
        end
    end
    for _, desc in Services.ReplicatedStorage:GetDescendants() do
        if (desc:IsA("RemoteEvent") or desc:IsA("RemoteFunction")) and string.find(desc.Name, "Favorite", 1, true) then
            favoriteRemote = desc
            favoriteRemotePath = desc:GetFullName()
            favoriteRemoteMode = string.find(desc.Name, "Toggle", 1, true) and "toggle" or "set"
            return desc
        end
    end
    return nil
end

