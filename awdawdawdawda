    if fpsBoosterConn then fpsBoosterConn:Disconnect() fpsBoosterConn = nil end
    if type(fpsBoosterRestore) == "function" then xpcall(fpsBoosterRestore, noopErr) fpsBoosterRestore = nil end
end

function fixLagDisconnectNonForeign(service, eventName)
    if type(getconnections) ~= "function" then return end
    if not service or type(eventName) ~= "string" then return end
    local signal = service[eventName]
    if not signal then return end
    local ok, connections = pcall(getconnections, signal)
    if not ok or type(connections) ~= "table" then return end
    for _, c in ipairs(connections) do
        if c and not c.ForeignState then
            pcall(function() c:Disconnect() end)
        end
    end
end

function fixLagPruneConnections(service, eventName)
    if type(getconnections) ~= "function" then return end
    if not service or type(eventName) ~= "string" then return end
    local signal = service[eventName]
    if not signal then return end
    local ok, connections = pcall(getconnections, signal)
    if not ok or type(connections) ~= "table" or #connections <= FIX_LAG_MAX_CONNECTIONS then return end
    for i = #connections, FIX_LAG_MAX_CONNECTIONS + 1, -1 do
        local c = connections[i]
        if c and not c.ForeignState then
            pcall(function() c:Disconnect() end)
        end
    end
end

function fixLagCleanupEffects()
    local Workspace = Services.Workspace
    local Debris = Services.Debris
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Beam") then
            local hum = obj.Parent and obj.Parent:FindFirstChildOfClass("Humanoid")
            if not hum then
                pcall(function() Debris:AddItem(obj, FIX_LAG_EFFECT_CLEANUP) end)
            end
        end
    end
end

function startFixLag()
    stopFixLag()
    local RunService = Services.RunService
    local LogService = Services.LogService
    local ScriptContext = Services.ScriptContext
    fixLagDisconnectNonForeign(LogService, "MessageOut")
    fixLagDisconnectNonForeign(ScriptContext, "Error")
    fixLagCleanupEffects()
    local lastCheck = os.clock()
    fixLagMainConn = RunService.Heartbeat:Connect(function()
        if os.clock() - lastCheck < FIX_LAG_CHECK_INTERVAL then return end
        lastCheck = os.clock()
        fixLagDisconnectNonForeign(LogService, "MessageOut")
        fixLagDisconnectNonForeign(ScriptContext, "Error")
        fixLagPruneConnections(RunService, "Heartbeat")
        fixLagPruneConnections(RunService, "Stepped")
        fixLagCleanupEffects()
    end)
end

function setFixLag(on)
    genv.ftgs_FixLag = on == true
    if genv.ftgs_FixLag then startFixLag() else stopFixLag() end
    saveConfig()
end

