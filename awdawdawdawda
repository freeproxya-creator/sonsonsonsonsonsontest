local function universalHttpGet(url)
    if game and type(game.HttpGet) == "function" then
        local ok, body = xpcall(function() return game:HttpGet(url) end, noopErr)
        if ok and type(body) == "string" and #body > 0 then return body end
    end
    local req = (syn and syn.request) or (http and http.request) or http_request or request
    if type(req) == "function" then
        local ok, res = xpcall(function() return req({ Url = url, Method = "GET" }) end, noopErr)
        if ok and res and type(res.Body or res.body) == "string" and #(res.Body or res.body) > 0 then
            return res.Body or res.body
        end
    end
    return nil
end

local function httpPost(url, body)
    if type(url) ~= "string" or url == "" or type(body) ~= "string" then return false end
    local headers = { ["Content-Type"] = "application/json", ["content-type"] = "application/json" }
    local req = request or (syn and syn.request) or (http and http.request) or http_request
    if fluxus and fluxus.request then req = fluxus.request end
    if type(req) == "function" then
        local ok, res = xpcall(function()
            return req({ Url = url, Method = "POST", Headers = headers, Body = body })
        end, noopErr)
        if ok then
            if res == true or res == nil then return true end
            local code = res and (res.StatusCode or res.status or res.Status)
            if type(code) == "number" then return code >= 200 and code < 400 end
            return true
        end
    end
    if http and type(http.post) == "function" then
        local ok = xpcall(function() http.post(url, body, "application/json") end, noopErr)
        if ok then return true end
    end
    if type(game.HttpPost) == "function" then
        local ok = xpcall(function() game:HttpPost(url, body, Enum.HttpContentType.ApplicationJson, false) end, noopErr)
        if ok then return true end
    end
    local hs = game:GetService("HttpService")
    if hs then
        local ok = xpcall(function()
            hs:PostAsync(url, body, Enum.HttpContentType.ApplicationJson, false)
        end, noopErr)
        if ok then return true end
        ok = xpcall(function()
            hs:RequestAsync({ Url = url, Method = "POST", Headers = headers, Body = body })
        end, noopErr)
        if ok then return true end
    end
    return false
end

