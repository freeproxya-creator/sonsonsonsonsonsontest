        if type(name) ~= "string" or name == "" or name == "Normal" then return end
        local key = string.lower(name)
        if seen[key] then return end
        seen[key] = true
        found[#found + 1] = name
    end
    for _, plot in (Gardens and Gardens:GetChildren() or {}) do
        local plants = plot:FindFirstChild("Plants")
        if plants then
            for _, plant in plants:GetChildren() do
                add(plant:GetAttribute("Mutation"))
                local fruits = plant:FindFirstChild("Fruits")
                if fruits then
                    for _, fr in fruits:GetChildren() do
                        add(fr:GetAttribute("Mutation"))
                    end
                end
            end
        end
    end
    for _, pd in pairs(trackedPlants) do
        if type(pd) == "table" then
