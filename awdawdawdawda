function stealFruit(fruit, ownerUserId, sessionId)
    if not autoStealOn() or sessionId ~= stealSessionId or not isNightTime() then return false end
    if not fruit or not fruit.Parent then return false end
    local stealPos, uid, plantId, fruitId = resolveStealTarget(fruit, ownerUserId)
    if not stealPos or not plantId then return false end
    if uid == nil then
        uid = tonumber(fruit:GetAttribute("UserId")) or tonumber(fruit:GetAttribute("OwnerUserId")) or ownerUserId or 0
    end

    local fruitCountBefore = getFruitCount()
    tpInstant(stealPos)

    for attempt = 1, STEAL_FRUIT_ATTEMPTS do
        if not autoStealOn() or sessionId ~= stealSessionId or not isNightTime() then break end
        if isStealComplete(fruit, fruitCountBefore) or not fruit.Parent then break end
        if attempt == 1 or attempt % 4 == 0 then tpInstant(stealPos) end
        local prompt = getStealPrompt(fruit)
        if prompt then fireProximityPromptFast(prompt) end
        safeNetCall(Net.Steal and Net.Steal.BeginSteal, uid, plantId, fruitId)
        safeNetCall(Net.Steal and Net.Steal.CompleteSteal)
        if STEAL_ATTEMPT_WAIT > 0 then task.wait(STEAL_ATTEMPT_WAIT) end
    end

    if not autoStealOn() or sessionId ~= stealSessionId then return false end

    if isStealComplete(fruit, fruitCountBefore) then
        StolenFruits[#StolenFruits + 1] = { name = fruit.Name .. " (" .. tostring(calculateStealValue(fruit)) .. ")", time = os.time() }
        markStealConfigDirty()
        cachedStealTargets = nil
        lastStealTargetScan = 0
        return true
    end
    return false
end

function tryAutoSteal()
    if not autoStealOn() or stealBusy or isInventoryFull() or not isNightTime() then return end
    stealBusy = true
    local sessionId = stealSessionId
    task.spawn(function()
        if sessionId ~= stealSessionId or not autoStealOn() or not isNightTime() then
            stealBusy = false
            return
        end

        movementBypass = true
        gardenActionLock = true
        local stolenTotal = 0

        while autoStealOn() and sessionId == stealSessionId and not isInventoryFull() and isNightTime() do
            local targets = collectAllStealTargets()
            if #targets == 0 then break end

            local gotOne = false
            for _, t in ipairs(targets) do
                if stolenTotal >= STEAL_BATCH then break end
                if sessionId ~= stealSessionId or not autoStealOn() or not isNightTime() then break end
                if isInventoryFull() then break end

                local plot = t.plot
                local owner = t.owner
                if owner and isOwnerInPlot(plot, owner) then continue end
                if owner and not plotUnlocked(owner) then continue end
                local uid = owner and owner.UserId or t.ownerUserId
                local fruits = getStealableFruitsOnPlot(plot, STEAL_BATCH - stolenTotal)

                for _, fruit in ipairs(fruits) do
                    if stolenTotal >= STEAL_BATCH then break end
                    if sessionId ~= stealSessionId or not autoStealOn() or not isNightTime() then break end
                    if isInventoryFull() then break end
                    if owner and isOwnerInPlot(plot, owner) then break end
                    if stealFruit(fruit, uid, sessionId) then
                        stolenTotal += 1
                        gotOne = true
                    end
                end
            end

            if stolenTotal >= STEAL_BATCH then
                teleportToGardenCenter()
                stolenTotal = 0
                cachedStealTargets = nil
                lastStealTargetScan = 0
                task.wait(STEAL_SESSION_GAP)
            elseif not gotOne then
                break
            end
        end

        finishStealSession(sessionId, true)
    end)
end

