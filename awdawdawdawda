function scanGardenForEmptySpot(force)
    local now = os.clock()
    if not force and cachedEmptySpot and now - lastEmptySpotScan < EMPTY_SPOT_CACHE_TTL then
        return cachedEmptySpot
    end
    if not OwnerPlot then refreshOwnerPlot() end
    if not OwnerPlot then return nil end
    if #plantAreas == 0 then
        cachePlantPositions(OwnerPlot)
        refreshPlantAreas()
    end
    if #plantAreas == 0 then return nil end
    local occupied = getOccupiedPlantPositionsCached()
    local best, bestScore
    for _, pos in plantAreas do
        if not isPosInsidePlot(pos, 2) then continue end
        if not isSpotEmpty(pos, occupied) then continue end
        local edge = savedPlotCenter and flatDistXZ(pos, savedPlotCenter) or 0
        if not best or edge > bestScore then best, bestScore = pos, edge end
    end
    cachedEmptySpot = best
    lastEmptySpotScan = now
    return best
end

