function setFruitFavoriteById(fruitId, entry, wantFavorite)
    initFavoriteRemotes()
    if fruitId == nil then return false end
    if entry and isFruitFavorited(entry) == wantFavorite then return false end
    if favoriteRemote and fireFavoriteRemote(favoriteRemote, fruitId, wantFavorite) then
        markFruitFavoriteState(entry, wantFavorite)
        return true
    end
    for _, info in scanNetFavoriteRemotes() do
        if fireFavoriteRemote(info.remote, fruitId, wantFavorite) then
            favoriteRemote = info.remote
            favoriteRemotePath = info.path
            markFruitFavoriteState(entry, wantFavorite)
            return true
        end
    end
    markFruitFavoriteState(entry, wantFavorite)
    return true
end

