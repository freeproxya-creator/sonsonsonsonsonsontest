function formatMinutesSeconds(totalSec)
    totalSec = math.max(0, math.floor(totalSec or 0))
    return string.format("%dm%02ds", math.floor(totalSec / 60), totalSec % 60)
end

function translateUiText(text, langCode)
    if type(text) ~= "string" or text == "" then return text end
    langCode = langCode or TRANSLATE_LANG_CODES[translateLanguage] or "en"
    if langCode == "en" then return text end
    local cacheKey = langCode .. ":" .. text
    if translationCache[cacheKey] then return translationCache[cacheKey] end
    local ok, result = xpcall(function()
        local url = "https://translate.googleapis.com/translate_a/single?client=gtx&sl=en&tl="
            .. langCode .. "&dt=t&q=" .. Services.HttpService:UrlEncode(text)
        local body = universalHttpGet(url)
        if not body then return text end
        local decoded = Services.HttpService:JSONDecode(body)
        local out = ""
        if decoded and decoded[1] then
            for _, chunk in decoded[1] do
                if chunk[1] then out = out .. chunk[1] end
            end
        end
        return out ~= "" and out or text
    end, noopErr)
    if ok and type(result) == "string" and result ~= "" then
        translationCache[cacheKey] = result
        return result
    end
    return text
end

function isHubUiInstance(inst)
    if not inst then return false end
    local p = inst
    while p do
        if p:IsA("ScreenGui") and (p:GetAttribute("NTMTHubUI") == true or hubScreenGuis[p]) then
            return true
        end
        p = p.Parent
    end
    return false
end

function markHubScreenGuis()
    local roots = {}
    pcall(function() roots[#roots + 1] = LocalPlayer.PlayerGui end)
    if type(gethui) == "function" then pcall(function() roots[#roots + 1] = gethui() end) end
    pcall(function() roots[#roots + 1] = game:GetService("CoreGui") end)
    for _, root in roots do
        if not root then continue end
        for _, sg in root:GetChildren() do
            if not sg:IsA("ScreenGui") then continue end
            local isHub = sg:GetAttribute("NTMTHubUI") == true
            local n = string.lower(sg.Name or "")
            if not isHub and (n:find("ntmt", 1, true) or n:find("ntmthub", 1, true) or n:find("windui", 1, true) or n:find("redz", 1, true)) then
                isHub = true
            end
            if not isHub then
                for _, d in sg:GetDescendants() do
                    if (d:IsA("TextButton") or d:IsA("TextLabel")) and type(d.Text) == "string" and d.Text:find("NTMT HUB", 1, true) then
                        isHub = true
                        break
                    end
                end
            end
            if isHub then
                sg:SetAttribute("NTMTHubUI", true)
                hubScreenGuis[sg] = true
            end
        end
    end
end

function getHubScreenGui()
    markHubScreenGuis()
    for sg in hubScreenGuis do
        if sg.Parent then return sg end
    end
    return nil
end

function rescanHubUiTextRegistry()
    markHubScreenGuis()
    for sg in hubScreenGuis do
        if sg.Parent then
            for _, d in sg:GetDescendants() do
                if d:IsA("TextLabel") or d:IsA("TextButton") or d:IsA("TextBox") then
                    if not translationRegistry[d] then registerUiTextInstance(d) end
                end
            end
        end
    end
end

function restoreAllUiText()
    rescanHubUiTextRegistry()
    for inst, data in translationRegistry do
        if inst and inst.Parent and isHubUiInstance(inst) then
            data.translating = true
            inst.Text = data.original or ""
            data.translating = false
        end
    end
end

function registerUiTextInstance(inst)
    if not inst or (not inst:IsA("TextLabel") and not inst:IsA("TextButton") and not inst:IsA("TextBox")) then return end
    if not isHubUiInstance(inst) then return end
    if translationRegistry[inst] then return end
    local data = { original = inst.Text or "", translating = false }
    translationRegistry[inst] = data
    inst:GetPropertyChangedSignal("Text"):Connect(function()
        if data.translating then return end
        local code = TRANSLATE_LANG_CODES[translateLanguage] or "en"
        if code == "en" then
            data.original = inst.Text
        end
    end)
end

function applyUiLanguage(langName)
    if langName then translateLanguage = langName end
    saveConfig()
    if translateBusy then return end
    translateBusy = true
    task.spawn(function()
        restoreAllUiText()
        rescanHubUiTextRegistry()
        local code = TRANSLATE_LANG_CODES[translateLanguage] or "en"
        if code == "en" then
            translateBusy = false
            hubNotify("Translate", "English restored")
            return
        end
        table.clear(translationCache)
        local unique, map = {}, {}
        for inst, data in translationRegistry do
            if inst and inst.Parent and isHubUiInstance(inst) and data.original and data.original ~= "" then
                if not map[data.original] then
                    map[data.original] = {}
                    unique[#unique + 1] = data.original
                end
                map[data.original][#map[data.original] + 1] = inst
            end
        end
        for _, text in unique do
            task.spawn(function()
                local out = translateUiText(text, code)
                for _, inst in map[text] or {} do
                    local data = translationRegistry[inst]
                    if data and inst.Parent then
                        data.translating = true
                        inst.Text = out
                        data.translating = false
                    end
                end
            end)
        end
        task.wait(1.8)
        translateBusy = false
        hubNotify("Translate", "NTMT UI → " .. translateLanguage)
    end)
end

function setupHubUiTranslationWatcher()
    markHubScreenGuis()
    local function watchSg(sg)
        if not sg or not sg:IsA("ScreenGui") then return end
        if sg:GetAttribute("NTMTHubUI") ~= true and not hubScreenGuis[sg] then return end
        hubScreenGuis[sg] = true
        for _, d in sg:GetDescendants() do registerUiTextInstance(d) end
        sg.DescendantAdded:Connect(function(d)
            task.defer(function()
                if isHubUiInstance(d) then registerUiTextInstance(d) end
            end)
        end)
    end
    for _, sg in LocalPlayer:WaitForChild("PlayerGui"):GetChildren() do watchSg(sg) end
    LocalPlayer.PlayerGui.ChildAdded:Connect(function(ch) task.defer(function() watchSg(ch) end) end)
end

function resolveThemeImageAsset(url, themeName)
    if not url or url == "" then return nil end
    if string.find(url, "rbxasset", 1, true) then return url end
    if writefile and isfile and getcustomasset then
        local fileName = "ntmthub/bg_" .. tostring(themeName or "theme") .. ".png"
        if not isfile(fileName) then
            local body = universalHttpGet(url)
            if type(body) == "string" and #body > 128 then
                pcall(function()
                    if makefolder then pcall(makefolder, "ntmthub") end
                    writefile(fileName, body)
                end)
            end
        end
        if isfile(fileName) then
            local ok, asset = pcall(getcustomasset, fileName)
            if ok and type(asset) == "string" and asset ~= "" then return asset end
        end
    end
    return url
end

function estimateFrameArea(frame)
    if not frame or not frame:IsA("GuiObject") then return 0 end
    local sz = frame.AbsoluteSize
    local area = sz.X * sz.Y
    if area > 0 then return area end
    local cam = workspace.CurrentCamera
    if not cam then return 0 end
    local vx = frame.Size.X.Offset + frame.Size.X.Scale * cam.ViewportSize.X
    local vy = frame.Size.Y.Offset + frame.Size.Y.Scale * cam.ViewportSize.Y
    return vx * vy
end

